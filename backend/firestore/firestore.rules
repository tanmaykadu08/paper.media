rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Portfolio items ──────────────────────────────────────
    // Public: anyone can read
    // Write: only authenticated owner
    match /portfolio/{docId} {
      allow read:  if true;
      allow write: if request.auth != null;
    }

    // ── Site content (hero, about text, etc.) ────────────────
    match /siteContent/{docId} {
      allow read:  if true;
      allow write: if request.auth != null;
    }

    // ── Shared links ─────────────────────────────────────────
    match /sharedLinks/{docId} {
      allow read:  if true;
      allow write: if request.auth != null;
    }

    // ── Client inquiries (contact form) ──────────────────────
    // Anyone can create (submit form), only owner can read
    match /inquiries/{docId} {
      allow create: if true;
      allow read, update, delete: if request.auth != null;
    }
  }
}
